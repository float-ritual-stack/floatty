# Required — floatty-server connection
FLOATTY_URL=http://127.0.0.1:8765
FLOATTY_API_KEY=your-api-key-here

# Required — AI Gateway (get from https://vercel.com/ai-gateway)
AI_GATEWAY_API_KEY=your-gateway-key-here

# Optional — override the default model (anthropic/claude-haiku-4.5)
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4-20250514
