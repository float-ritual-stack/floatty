{
  "name": "floatty-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "turbo": "^2.6.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:run": "pnpm --filter float-pty test:run",
    "lint": "turbo run lint",
    "preview": "pnpm --filter float-pty preview",
    "tauri": "pnpm --filter float-pty tauri",
    "tauri:dev": "pnpm --filter float-pty tauri:dev",
    "tauri:dev:fresh": "pnpm --filter float-pty tauri:dev:fresh",
    "kill-server": "pnpm --filter float-pty kill-server"
  }
}
