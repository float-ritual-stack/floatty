{
  "name": "float-pty",
  "private": true,
  "version": "0.7.26",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "lsof -ti :8766 | xargs kill 2>/dev/null || true; RUST_LOG=debug FLOATTY_DATA_DIR=$HOME/.floatty-dev tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:dev:fresh": "lsof -ti :8766 | xargs kill 2>/dev/null || true; cd src-tauri && cargo build -p floatty-server && cd .. && RUST_LOG=debug FLOATTY_DATA_DIR=$HOME/.floatty-dev tauri dev --config src-tauri/tauri.dev.conf.json",
    "kill-server": "lsof -ti :8765 :8766 :33333 2>/dev/null | xargs kill 2>/dev/null && echo 'Killed servers' || echo 'No servers running'",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@solid-primitives/keyed": "^1.5.2",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-ligatures": "^0.9.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "solid-js": "^1.9.3",
    "tauri-plugin-clipboard-api": "2.1.11",
    "tauri-pty": "^0.1.1",
    "tinykeys": "^3.0.0",
    "yjs": "^13.6.28"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^4.0.16"
  }
}
