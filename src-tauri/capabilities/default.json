{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "pty:allow-spawn",
    "pty:allow-read",
    "pty:allow-write",
    "pty:allow-resize",
    "pty:allow-kill",
    "pty:allow-exitstatus",
    "os:default",
    "clipboard:read-all",
    "clipboard:write-all"
  ]
}
