{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:webview:allow-set-webview-zoom",
    "pty:allow-spawn",
    "pty:allow-read",
    "pty:allow-write",
    "pty:allow-resize",
    "pty:allow-kill",
    "pty:allow-exitstatus",
    "os:default",
    "clipboard:read-all",
    "clipboard:write-all",
    "dialog:default",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**/*" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$HOME/**/*" }]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/.floatty/**/*" },
        { "path": "$HOME/.floatty-dev/**/*" },
        { "path": "$HOME/float-hub/**/*" },
        { "path": "$HOME/float-hub-operations/**/*" },
        { "path": "$HOME/projects/**/*" },
        { "path": "/opt/float/**/*" }
      ]
    },
    "mcp-bridge:default",
    "window-state:default"
  ]
}
