{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "pty:allow-spawn",
    "pty:allow-read",
    "pty:allow-write",
    "pty:allow-resize",
    "pty:allow-kill",
    "pty:allow-exitstatus",
    "os:default"
  ]
}
