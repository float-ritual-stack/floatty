{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "float-pty",
  "version": "0.10.2",
  "identifier": "dev.float.floatty",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5188",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "float-pty",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/floatty-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "floatty"
        ]
      }
    }
  }
}
